{
  "name": "@dbaida/pi-sync",
  "version": "1.0.0",
  "description": "Pi extension that syncs Pi configuration through a Git repository.",
  "type": "module",
  "packageManager": "yarn@4.16.0",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "sync",
    "git"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/sync.ts"
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@dbaida/eslint-config": "1.0.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
